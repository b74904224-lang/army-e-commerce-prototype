# ---------------------------------------------------------------------------
# ARMY Store API — environment configuration (OVHcloud deployment)
# Copy to `.env` and fill in real values. NEVER commit the real .env file.
# ---------------------------------------------------------------------------

# HTTP port the API listens on (behind Nginx in production).
PORT=4000

# Node environment: development | production
NODE_ENV=production

# Comma-separated list of allowed CORS origins (your Vercel frontend URLs).
# Example: https://army-store.vercel.app,https://www.army-store.com
CORS_ORIGINS=http://localhost:3000

# Secret used to sign JWT access tokens. Generate with:
#   openssl rand -base64 48
JWT_SECRET=
# Token lifetime (zeit/ms format, e.g. 7d, 12h, 30m).
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# SMTP / email (order notifications via Nodemailer)
# ---------------------------------------------------------------------------
# When SMTP_HOST is empty, the mailer logs orders to the console instead of
# sending email (useful for local development).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Address that order notification emails are sent FROM and TO.
ORDER_NOTIFICATION_FROM="ARMY Store <no-reply@army-store.com>"
ORDER_NOTIFICATION_TO=orders@army-store.com
