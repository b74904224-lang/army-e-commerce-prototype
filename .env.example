# Base URL of the external OVHcloud backend server.
# Set this to the OVHcloud server IP or your custom API subdomain.
# Examples:
#   NEXT_PUBLIC_API_URL=https://api.army-store.com
#   NEXT_PUBLIC_API_URL=https://51.210.0.0
#
# When unset, the storefront falls back to bundled catalog data and local
# mock auth so the UI still works in preview / CI.
NEXT_PUBLIC_API_URL=
