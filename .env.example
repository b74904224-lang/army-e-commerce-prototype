# Base URL of the external OVHcloud backend server.
# Set this to the OVHcloud server IP or your custom API subdomain.
# Examples:
#   NEXT_PUBLIC_API_URL=https://api.army-store.com
#   NEXT_PUBLIC_API_URL=https://51.210.0.0
#
# When unset, product browsing still works from bundled catalog data, but
# placing orders and authentication are disabled (the UI shows a clear
# "server unavailable" message instead of faking a successful order).
NEXT_PUBLIC_API_URL=
